# Copy to a non-committed .env.staging file on the approved staging host.
# Blank values are intentional. Generate them on the host; never commit them.
APP_ENV=staging
STAGING_SERVER_NAME=staging.example.invalid
WEB_ORIGIN=https://staging.example.invalid
APP_BASE_URL=https://staging.example.invalid
LOG_LEVEL=info

POSTGRES_DB=etsy_saas
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
APP_DATABASE_PASSWORD=
DATABASE_URL=
DATABASE_ADMIN_URL=

PASSWORD_PEPPER=
SESSION_COOKIE_NAME=etsy_saas_session
SESSION_TTL_HOURS=168
VERIFICATION_TOKEN_TTL_MINUTES=60
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=etsy-saas-staging
S3_REGION=us-east-1

EMAIL_FROM_NAME="Etsy SaaS Staging"
EMAIL_FROM_ADDRESS=noreply@staging.invalid
ETSY_INTEGRATION_ENABLED=false

# Set only after an approved certificate provisioning step.
TLS_CERT_DIR=
