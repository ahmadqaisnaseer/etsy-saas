{
  "name": "etsy-saas-foundation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Multi-tenant Etsy SaaS foundation (no live Etsy integration)",
  "packageManager": "pnpm@10.13.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm --filter @etsy-saas/shared build && pnpm --filter @etsy-saas/api build && pnpm --filter @etsy-saas/worker build && pnpm --filter @etsy-saas/web build",
    "dev": "concurrently -n api,web,worker -c blue,green,magenta \"pnpm --filter @etsy-saas/api dev\" \"pnpm --filter @etsy-saas/web dev\" \"pnpm --filter @etsy-saas/worker dev\"",
    "dev:infra": "docker compose up -d postgres redis minio createbucket",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "pnpm --filter @etsy-saas/shared build && eslint . --max-warnings=0",
    "test": "vitest run --configLoader runner",
    "test:watch": "vitest --configLoader runner",
    "test:integration": "vitest run --config vitest.integration.config.ts --configLoader runner",
    "typecheck": "pnpm --filter @etsy-saas/shared build && pnpm --recursive typecheck",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:migrate:docker": "docker compose run --rm migrate"
  },
  "dependencies": {
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "@types/node": "^22.15.0",
    "@types/pg": "^8.15.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.30.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.2.0",
    "prettier": "^3.6.0",
    "tsx": "4.20.6",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.0"
  },
  "pnpm": {
    "overrides": {
      "tsx": "4.20.6"
    }
  }
}
