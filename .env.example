# Copy to .env for Docker Compose or to apps/*/.env for local processes.
APP_ENV=development
LOG_LEVEL=debug
WEB_ORIGIN=http://localhost:5173
API_PORT=3000
DATABASE_URL=postgresql://app:app@localhost:5432/etsy_saas
DATABASE_ADMIN_URL=postgresql://postgres:postgres@localhost:5432/etsy_saas
REDIS_URL=redis://localhost:6379
SESSION_COOKIE_NAME=etsy_saas_session
SESSION_TTL_HOURS=168
PASSWORD_PEPPER=replace-with-at-least-32-random-characters
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=etsy-saas-local
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio-secret
S3_FORCE_PATH_STYLE=true
# Etsy is intentionally disabled. No OAuth credentials are required or used.
ETSY_INTEGRATION_ENABLED=false

